# ── Database (use Render's PostgreSQL Internal URL) ──────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── JWT (CHANGE THIS! Generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
JWT_SECRET_KEY=CHANGE-ME-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=FItTrade LMS
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=https://your-frontend.vercel.app

# ── AI / OpenAI (optional — leave empty to disable AI tutor) ─────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-ada-002

# ── Milvus (disabled for free-tier deployment) ───────────────────────
USE_MILVUS=false

# ── Email (SMTP stub — configure if needed) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@fittrade.com

# ── Redis (disabled for free-tier deployment) ────────────────────────
REDIS_URL=
